flowchart LR
    FOCUS["Фокусный контакт"] --> RECALL["Восстановление без источника"]
    RECALL --> TRACE["Первичный след / чанк-кандидат"]
    TRACE --> PAUSE["Пауза"]
    PAUSE --> SLEEP["Сон и восстановление"]
    SLEEP --> CONS["Консолидация и реорганизация"]
    CONS --> NEXT["Следующее касание"]
    NEXT --> RET["Повторное извлечение"]
    RET --> UPDATE["Уточнение / реконсолидация"]
    UPDATE --> STABLE["Более устойчивый чанк"]
    STABLE --> USE["Применение и перенос"]
