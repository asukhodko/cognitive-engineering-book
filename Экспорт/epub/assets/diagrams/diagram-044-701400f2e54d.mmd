flowchart LR
    BEFORE["До ИИ: цель, контекст, гипотеза, критерий"] --> ROLE["Выбор роли ИИ"]
    ROLE --> DIALOG["Диалог: варианты, вопросы, критика, черновик"]
    DIALOG --> CHECK["Проверка: источник, тест, пример, контрпример"]
    CHECK --> DECIDE["Решение человека"]
    DECIDE --> TRACE["След: что принято, почему, что дальше"]
    TRACE --> SKILL["Навык и следующий вход"]

    BEFORE -. "если пропустить" .-> VAGUE["Туманный запрос"]
    VAGUE -.-> READY["Готовый ответ"]
    READY -.-> COPY["Перенос без проверки"]
    COPY -.-> LOSS["Потеря авторства и слабый след"]
