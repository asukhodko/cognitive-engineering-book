flowchart LR
    DEMAND["Требования и входящие"] --> WIP["Командный WIP"]
    WIP --> SWITCH["Переключения и прерывания"]
    SWITCH --> COST["Цена восстановления контекста"]
    COST --> AGING["Старение задач и тревога"]
    AGING --> URGENCY["Рост срочности"]
    URGENCY --> SWITCH

    WIP --> LOAD["Нагрузка и восстановительный долг"]
    LOAD --> RISK["Риск выгорания/профессиональной скуки"]

    STATE["Внешнее состояние треков"] --> COST
    RULES["Правила срочности"] --> SWITCH
    CADENCE["Каденции обратной связи"] --> AGING
    RECOVERY["Восстановимый ритм"] --> LOAD
