flowchart LR
    TASK["Задача и контекст"] --> HUMAN["Своя гипотеза"]
    HUMAN --> ASK["Запрос к ИИ"]
    ASK --> AI["Ответ ИИ: варианты, черновик, критика"]
    AI --> CHECK["Проверка: источник, тест, пример, контрпример"]
    CHECK --> DECIDE["Решение человека"]
    DECIDE --> TRACE["След в рабочем журнале"]
    TRACE --> NEXT["Следующий вход дешевле"]

    TASK -. "обход" .-> VAGUE["Туманный запрос"]
    VAGUE -.-> READY["Готовый ответ"]
    READY -.-> COPY["Перенос без проверки"]
    COPY -.-> FRAGILE["Хрупкий результат"]
    FRAGILE -.-> NEXT_BAD["Следующий вход не стал дешевле"]
