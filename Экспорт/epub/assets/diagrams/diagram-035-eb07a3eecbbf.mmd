flowchart LR
    WIP["Меньше активного WIP"] --> ENTRY["Глубже вход"]
    ENTRY --> WORK["Один вопрос или гипотеза"]
    WORK --> SLICE["Срез продвижения"]
    SLICE --> CHECK["Контрольная точка"]
    CHECK --> OUT["Контекст вынесен наружу"]
    OUT --> RETURN["Следующий вход дешевле"]
    RETURN --> ENTRY
