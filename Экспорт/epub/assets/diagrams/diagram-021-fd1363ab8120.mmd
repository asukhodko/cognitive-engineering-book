flowchart TD
    ENV["Ситуация и задача"] --> PFC["Префронтальная кора (PFC): цель, правило, модель задачи"]
    ENV --> HPC["Гиппокамп: контекст и память"]
    ENV --> AMY["Миндалина / BNST / PAG: угроза и защита"]
    BODY["Тело: сон, напряжение, усталость"] --> INS["Островок: интероцепция и значимость"]
    HPC --> PFC
    HPC --> AMY
    INS --> ACC["Поясной узел (ACC/aMCC): конфликт, цена контроля, усилие"]
    AMY --> ACC
    PFC --> ACC
    PFC --> STR["Стриатум и базальные ганглии: выбор и запуск действия"]
    ACC --> STR
    AMY --> STR
    INS --> STR
    STR --> ACT["Политика действия"]
    ACT --> FB["Исход и обратная связь"]
    FB --> HPC
    FB --> STR
    FB --> PFC
    FB --> AMY
